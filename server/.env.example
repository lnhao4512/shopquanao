PORT=3001

# Option A: Full MongoDB URI (recommended)
# DB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/shoponline?retryWrites=true&w=majority

# Option B: Parts (only used if DB_URI is empty)
DB_SERVER=cluster.mongodb.net
DB_USER=
DB_PASS=
DB_DATABASE=shoponline

# JWT
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES=3600000

# Email (optional, for signup activation)
EMAIL_USER=
EMAIL_PASS=

